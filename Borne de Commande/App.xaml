<Application x:Class="Borne_de_Commande.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Borne_de_Commande.ViewModels"
             xmlns:views="clr-namespace:Borne_de_Commande.Views"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!-- ══════════════════════════════════════════════════════════
             DataTemplates : associe chaque ViewModel à sa View.
             WPF choisit automatiquement la bonne vue via ContentControl.
             ══════════════════════════════════════════════════════════ -->
        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <views:HomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BorneViewModel}">
            <views:BorneView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:GestionUtilisateursViewModel}">
            <views:GestionUtilisateursView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:GestionCategoriesViewModel}">
            <views:GestionCategoriesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:GestionProduitsViewModel}">
            <views:GestionProduitsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CuisineViewModel}">
            <views:CuisineView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PaiementViewModel}">
            <views:PaiementView />
        </DataTemplate>

        <!-- ══════════════════════════════════════════════════════════
             Palette de couleurs
             ══════════════════════════════════════════════════════════ -->
        <Color x:Key="PrimaryColor">#1A1A2E</Color>
        <Color x:Key="AccentColor">#E94560</Color>
        <Color x:Key="AccentLightColor">#FF6B81</Color>
        <Color x:Key="SurfaceColor">#16213E</Color>
        <Color x:Key="CardColor">#0F3460</Color>
        <Color x:Key="TextColor">#EAEAEA</Color>
        <Color x:Key="MutedColor">#8892B0</Color>
        <Color x:Key="SuccessColor">#2ECC71</Color>
        <Color x:Key="WarningColor">#F39C12</Color>

        <SolidColorBrush x:Key="PrimaryBrush"     Color="{StaticResource PrimaryColor}" />
        <SolidColorBrush x:Key="AccentBrush"      Color="{StaticResource AccentColor}" />
        <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource AccentLightColor}" />
        <SolidColorBrush x:Key="SurfaceBrush"     Color="{StaticResource SurfaceColor}" />
        <SolidColorBrush x:Key="CardBrush"        Color="{StaticResource CardColor}" />
        <SolidColorBrush x:Key="TextBrush"        Color="{StaticResource TextColor}" />
        <SolidColorBrush x:Key="MutedBrush"       Color="{StaticResource MutedColor}" />
        <SolidColorBrush x:Key="SuccessBrush"     Color="{StaticResource SuccessColor}" />
        <SolidColorBrush x:Key="WarningBrush"     Color="{StaticResource WarningColor}" />

        <!-- ══════════════════════════════════════════════════════════
             Style global des boutons
             ══════════════════════════════════════════════════════════ -->
        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background"   Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground"   Value="White" />
            <Setter Property="FontWeight"   Value="Bold" />
            <Setter Property="FontSize"     Value="14" />
            <Setter Property="Padding"      Value="16 8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor"       Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentLightBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="SecondaryButton" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
        </Style>

        <Style TargetType="Button" x:Key="DangerButton" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#C0392B" />
        </Style>

        <Style TargetType="Button" x:Key="SuccessButton" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{StaticResource SuccessBrush}" />
        </Style>

        <!-- TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background"        Value="#1E2A4A" />
            <Setter Property="Foreground"        Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush"       Value="#334070" />
            <Setter Property="BorderThickness"   Value="1" />
            <Setter Property="Padding"           Value="8 5" />
            <Setter Property="FontSize"          Value="13" />
            <Setter Property="CaretBrush"        Value="{StaticResource TextBrush}" />
        </Style>

        <!-- ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"      Value="#1E2A4A" />
            <Setter Property="Foreground"      Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush"     Value="#334070" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"         Value="8 5" />
            <Setter Property="FontSize"        Value="13" />
        </Style>

        <!-- DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"            Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Foreground"            Value="{StaticResource TextBrush}" />
            <Setter Property="RowBackground"         Value="{StaticResource SurfaceBrush}" />
            <Setter Property="AlternatingRowBackground" Value="#1A2547" />
            <Setter Property="BorderThickness"       Value="0" />
            <Setter Property="GridLinesVisibility"   Value="None" />
            <Setter Property="HeadersVisibility"     Value="Column" />
            <Setter Property="AutoGenerateColumns"   Value="False" />
            <Setter Property="CanUserAddRows"        Value="False" />
            <Setter Property="SelectionMode"         Value="Single" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"    Value="{StaticResource CardBrush}" />
            <Setter Property="Foreground"    Value="{StaticResource TextBrush}" />
            <Setter Property="FontWeight"    Value="Bold" />
            <Setter Property="Padding"       Value="10 6" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"         Value="10 4" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

    </Application.Resources>
</Application>
