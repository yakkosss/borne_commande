<UserControl x:Class="Borne_de_Commande.Views.GestionProduitsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource PrimaryBrush}">

    <!-- Les resources DOIVENT etre declarees avant leur utilisation en StaticResource -->
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <!-- Titre -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   Text="Gestion des produits" FontSize="22" FontWeight="Bold"
                   Foreground="{StaticResource TextBrush}" Margin="0 0 0 16" />

        <!-- Barre d'outils : filtre + bascule vue -->
        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0 0 0 12">
            <TextBlock Text="Filtrer par categorie :" VerticalAlignment="Center"
                       Foreground="{StaticResource MutedBrush}" Margin="0 0 8 0" />
            <ComboBox ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding FiltreCategorie, Mode=TwoWay}"
                      DisplayMemberPath="Nom" Width="180" />
            <Button Content="{Binding ModeTableau, Converter={x:Static local:BoolToModeConverter.Instance}}"
                    Command="{Binding BasculerModeCommand}"
                    Style="{StaticResource SecondaryButton}" Margin="12 0 0 0"
                    xmlns:local="clr-namespace:Borne_de_Commande.Views" />
        </StackPanel>

        <!-- ── Zone principale : DataGrid ou ListBox ──────────────────── -->
        <Border Grid.Row="2" Grid.Column="0" Margin="0 0 16 0"
                Background="{StaticResource SurfaceBrush}" CornerRadius="8">
            <Grid>
                <!-- Mode tableau (DataGrid) -->
                <DataGrid ItemsSource="{Binding Produits}"
                          SelectedItem="{Binding Selected, Mode=TwoWay}"
                          Visibility="{Binding ModeTableau, Converter={StaticResource BoolToVisibilityConverter}}"
                          Margin="8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"          Binding="{Binding Id}"                Width="50" />
                        <DataGridTextColumn Header="Nom"         Binding="{Binding Nom}"               Width="*" />
                        <DataGridTextColumn Header="Prix (€)"    Binding="{Binding Prix, StringFormat=N2}" Width="80" />
                        <DataGridTextColumn Header="Categorie"   Binding="{Binding Categorie.Nom}"     Width="140" />
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}"       Width="200" />
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Mode liste (ListBox avec cards) -->
                <ListBox ItemsSource="{Binding Produits}"
                         SelectedItem="{Binding Selected, Mode=TwoWay}"
                         Background="Transparent" BorderThickness="0"
                         Visibility="{Binding ModeListe, Converter={StaticResource BoolToVisibilityConverter}}"
                         Margin="8">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource CardBrush}" CornerRadius="6"
                                    Padding="12 8" Margin="0 3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Nom}" FontWeight="Bold"
                                                   Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="{Binding Categorie.Nom}"
                                                   Foreground="{StaticResource MutedBrush}" FontSize="11" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                               Text="{Binding Prix, StringFormat={}{0:N2} €}"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontWeight="Bold" FontSize="15" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Padding"    Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>

        <!-- ── Formulaire ─────────────────────────────────────────────── -->
        <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="1"
                Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Formulaire" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" Margin="0 0 0 16" />

                    <TextBlock Text="Nom *" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0 0 0 4" />
                    <TextBox Text="{Binding NomEdition, UpdateSourceTrigger=PropertyChanged}" Margin="0 0 0 12" />

                    <TextBlock Text="Prix (€) *" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0 0 0 4" />
                    <TextBox Text="{Binding PrixEdition, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Margin="0 0 0 12" />

                    <TextBlock Text="Categorie" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0 0 0 4" />
                    <ComboBox ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding CategorieEdition, Mode=TwoWay}"
                              DisplayMemberPath="Nom" Margin="0 0 0 12" />

                    <TextBlock Text="Description" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0 0 0 4" />
                    <TextBox Text="{Binding DescriptionEdition, UpdateSourceTrigger=PropertyChanged}"
                             Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0 0 0 16" />

                    <Button Content="➕  Ajouter"
                            Command="{Binding AjouterCommand}"
                            Style="{StaticResource SuccessButton}"
                            HorizontalAlignment="Stretch" Margin="0 0 0 8" />
                    <Button Content="✏️  Modifier"
                            Command="{Binding ModifierCommand}"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Stretch" Margin="0 0 0 8" />
                    <Button Content="🗑️  Supprimer"
                            Command="{Binding SupprimerCommand}"
                            Style="{StaticResource DangerButton}"
                            HorizontalAlignment="Stretch" Margin="0 0 0 8" />
                    <Button Content="🔄  Nouveau"
                            Command="{Binding NouveauCommand}"
                            Style="{StaticResource SecondaryButton}"
                            HorizontalAlignment="Stretch" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>

</UserControl>
