<UserControl x:Class="Borne_de_Commande.Views.BorneView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource PrimaryBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Colonne categories -->
            <ColumnDefinition Width="180" />
            <!-- Colonne produits -->
            <ColumnDefinition Width="*" />
            <!-- Colonne panier -->
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════════════
             Colonne 1 – Categories
             ══════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}">
            <StackPanel>
                <TextBlock Text="Categories" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource MutedBrush}"
                           Margin="12 16 12 8" />
                <ItemsControl ItemsSource="{Binding Categories}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Nom}"
                                    Command="{Binding DataContext.SelectionnerCategorieCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Padding="14 12"
                                    Margin="0 1"
                                    Background="Transparent"
                                    Foreground="{StaticResource TextBrush}"
                                    BorderThickness="0"
                                    FontSize="14"
                                    Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background"  Value="Transparent" />
                                        <Setter Property="Foreground"  Value="{StaticResource TextBrush}" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Cursor"      Value="Hand" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd"
                                                            Background="{TemplateBinding Background}"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Left"
                                                                          VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background"
                                                                    Value="{StaticResource CardBrush}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════
             Colonne 2 – Produits
             ══════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1" Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Nom de la categorie active -->
            <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="20 14">
                <TextBlock Text="{Binding CategorieActive.Nom}"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}" />
            </Border>

            <!-- Grille de produits -->
            <ScrollViewer Grid.Row="1" Padding="16">
                <ItemsControl ItemsSource="{Binding Produits}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Card produit -->
                            <Border Width="160" Height="160" Margin="8"
                                    Background="{StaticResource CardBrush}"
                                    CornerRadius="10" Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.AjouterAuPanierCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}" />
                                </Border.InputBindings>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                            Margin="12">
                                    <TextBlock Text="🍽️" FontSize="32"
                                               HorizontalAlignment="Center" Margin="0 0 0 8" />
                                    <TextBlock Text="{Binding Nom}" TextWrapping="Wrap"
                                               FontWeight="Bold" FontSize="13"
                                               Foreground="{StaticResource TextBrush}"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center" />
                                    <TextBlock Text="{Binding Prix, StringFormat={}{0:N2} €}"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontWeight="Bold" FontSize="15"
                                               HorizontalAlignment="Center" Margin="0 6 0 0" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════
             Colonne 3 – Panier
             ══════════════════════════════════════════════════════════ -->
        <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- En-tete panier -->
                <Border Grid.Row="0" Background="{StaticResource CardBrush}" Padding="16 12">
                    <TextBlock Text="🛒  Mon panier" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" />
                </Border>

                <!-- Liste des articles -->
                <ScrollViewer Grid.Row="1" Padding="12">
                    <ItemsControl ItemsSource="{Binding Panier}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource CardBrush}"
                                        CornerRadius="6" Padding="10" Margin="0 4">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <!-- Nom + supprimer -->
                                        <Grid Grid.Row="0">
                                            <TextBlock Text="{Binding Produit.Nom}"
                                                       Foreground="{StaticResource TextBrush}"
                                                       FontWeight="Bold" FontSize="13"
                                                       TextWrapping="Wrap"
                                                       VerticalAlignment="Center" />
                                            <Button Content="✕" HorizontalAlignment="Right"
                                                    Background="Transparent" Foreground="#E74C3C"
                                                    BorderThickness="0" FontWeight="Bold" Cursor="Hand"
                                                    Command="{Binding DataContext.RetirerDuPanierCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" />
                                        </Grid>
                                        <!-- Quantite + sous-total -->
                                        <Grid Grid.Row="1" Margin="0 6 0 0">
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="−" Width="26" Height="26"
                                                        Background="{StaticResource SurfaceBrush}"
                                                        Foreground="{StaticResource TextBrush}"
                                                        BorderThickness="0" FontWeight="Bold" Cursor="Hand"
                                                        Command="{Binding DataContext.DiminuerQuantiteCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}" />
                                                <TextBlock Text="{Binding Quantite}"
                                                           Foreground="{StaticResource TextBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="8 0" FontWeight="Bold" />
                                                <Button Content="+" Width="26" Height="26"
                                                        Background="{StaticResource SurfaceBrush}"
                                                        Foreground="{StaticResource TextBrush}"
                                                        BorderThickness="0" FontWeight="Bold" Cursor="Hand"
                                                        Command="{Binding DataContext.AugmenterQuantiteCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding SousTotal, StringFormat={}{0:N2} €}"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontWeight="Bold" HorizontalAlignment="Right"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Pied de page : total + boutons -->
                <Border Grid.Row="2" Background="{StaticResource CardBrush}" Padding="16">
                    <StackPanel>
                        <Grid Margin="0 0 0 12">
                            <TextBlock Text="TOTAL" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource MutedBrush}" />
                            <TextBlock Text="{Binding Total, StringFormat={}{0:N2} €}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Right" />
                        </Grid>

                        <Button Content="✅  Valider le panier"
                                Command="{Binding ValiderPanierCommand}"
                                Style="{StaticResource SuccessButton}"
                                HorizontalAlignment="Stretch"
                                FontSize="16" Padding="0 14"
                                Margin="0 0 0 8" />

                        <Button Content="🗑️  Vider le panier"
                                Command="{Binding ViderPanierCommand}"
                                Style="{StaticResource DangerButton}"
                                HorizontalAlignment="Stretch"
                                FontSize="13" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
