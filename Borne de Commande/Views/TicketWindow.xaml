<Window x:Class="Borne_de_Commande.Views.TicketWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ticket" Width="400" Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource PrimaryBrush}">

    <Border Padding="24" Background="{StaticResource SurfaceBrush}"
            Margin="16" CornerRadius="12">
        <StackPanel>

            <!-- En-tete selon le type de ticket -->
            <Border x:Name="HeaderBorder" CornerRadius="8" Padding="12 8"
                    HorizontalAlignment="Center" Margin="0 0 0 12">
                <TextBlock x:Name="TitreTicket" FontSize="16" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center" />
            </Border>

            <TextBlock Text="🍔  Borne de Commande" FontSize="16" FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" />

            <Rectangle Height="1" Fill="{StaticResource CardBrush}" Margin="0 12" />

            <!-- Infos commande -->
            <Grid Margin="0 0 0 6">
                <TextBlock Text="N° commande" Foreground="{StaticResource MutedBrush}" />
                <TextBlock Text="{Binding NumeroCommande}"
                           HorizontalAlignment="Right" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}" />
            </Grid>
            <Grid Margin="0 0 0 6">
                <TextBlock Text="Date" Foreground="{StaticResource MutedBrush}" />
                <TextBlock Text="{Binding DateCreation, StringFormat='dd/MM/yyyy HH:mm'}"
                           HorizontalAlignment="Right" Foreground="{StaticResource TextBrush}" />
            </Grid>
            <Grid Margin="0 0 0 12" x:Name="PaiementGrid">
                <TextBlock Text="Paiement" Foreground="{StaticResource MutedBrush}" />
                <TextBlock Text="{Binding ModePaiement}"
                           HorizontalAlignment="Right" Foreground="{StaticResource TextBrush}" />
            </Grid>

            <Rectangle Height="1" Fill="{StaticResource CardBrush}" Margin="0 0 0 10" />

            <!-- Lignes -->
            <ItemsControl ItemsSource="{Binding Lignes}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0 3">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Quantite}"
                                           Foreground="{StaticResource MutedBrush}" Margin="0 0 6 0" />
                                <TextBlock Text="×" Foreground="{StaticResource MutedBrush}" Margin="0 0 6 0" />
                                <TextBlock Text="{Binding NomProduit}" Foreground="{StaticResource TextBrush}" />
                            </StackPanel>
                            <TextBlock x:Name="PrixLigne"
                                       Text="{Binding SousTotal, StringFormat={}{0:N2} €}"
                                       HorizontalAlignment="Right"
                                       Foreground="{StaticResource TextBrush}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Rectangle Height="1" Fill="{StaticResource CardBrush}" Margin="0 10" />

            <!-- Total (ticket client uniquement) -->
            <Grid x:Name="TotalGrid" Margin="0 0 0 20">
                <TextBlock Text="TOTAL" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}" />
                <TextBlock Text="{Binding Total, StringFormat={}{0:N2} €}"
                           HorizontalAlignment="Right" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" />
            </Grid>

            <!-- Statut -->
            <Border Background="{StaticResource WarningBrush}" CornerRadius="6"
                    Padding="10 6" HorizontalAlignment="Center" Margin="0 0 0 20">
                <TextBlock Text="⏳  Commande transmise en cuisine"
                           Foreground="White" FontWeight="Bold" />
            </Border>

            <Button Content="Fermer" Click="FermerClick"
                    Style="{StaticResource PrimaryButton}"
                    HorizontalAlignment="Stretch" FontSize="15" Padding="0 12" />
        </StackPanel>
    </Border>
</Window>
