<Window x:Class="Borne_de_Commande.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connexion" Height="320" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1A1A2E">

    <Grid Margin="36">
        <StackPanel VerticalAlignment="Center">

            <!-- Header -->
            <TextBlock Text="&#128274;  Connexion requise" FontSize="20" FontWeight="Bold"
                       Foreground="White" HorizontalAlignment="Center" Margin="0 0 0 6"/>
            <TextBlock Text="Acces reserve au personnel" FontSize="12"
                       Foreground="#8892B0" HorizontalAlignment="Center" Margin="0 0 0 28"/>

            <!-- Role -->
            <TextBlock Text="Role" Foreground="#8892B0" FontSize="12" Margin="0 0 0 4"/>
            <ComboBox x:Name="RoleBox"
                      Background="#1E2A4A" Foreground="White" BorderBrush="#334070"
                      BorderThickness="1" Padding="8 6" FontSize="13"
                      Margin="0 0 0 14"
                      SelectedIndex="0">
                <ComboBox.Resources>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#1E2A4A"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontSize"   Value="13"/>
                        <Setter Property="Padding"    Value="8 6"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#334070"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#334070"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ComboBox.Resources>
                <ComboBoxItem Content="Administrateur" Tag="admin" />
                <ComboBoxItem Content="Cuisine"        Tag="cuisine" />
            </ComboBox>

            <!-- Mot de passe -->
            <TextBlock Text="Mot de passe" Foreground="#8892B0" FontSize="12" Margin="0 0 0 4"/>
            <PasswordBox x:Name="PwdBox"
                         Background="#1E2A4A" Foreground="White" BorderBrush="#334070"
                         BorderThickness="1" Padding="8 6" FontSize="13"
                         Margin="0 0 0 18"/>

            <!-- Message d'erreur -->
            <TextBlock x:Name="ErrorText" Foreground="#E94560" FontSize="12"
                       HorizontalAlignment="Center" Margin="0 0 0 14" Visibility="Collapsed"/>

            <!-- Bouton connexion -->
            <Button Content="Se connecter" Click="BtnConnexion_Click"
                    Style="{StaticResource PrimaryButton}"
                    HorizontalAlignment="Stretch" FontSize="14" Padding="0 14"/>
        </StackPanel>
    </Grid>
</Window>
