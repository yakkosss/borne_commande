<UserControl x:Class="Borne_de_Commande.Views.CuisineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource PrimaryBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- En-tete -->
        <Grid Grid.Row="0" Margin="0 0 0 16">
            <TextBlock Text="&#128104;&#8205;&#127859;  Interface cuisine" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}" />
            <Button Content="&#128260;  Actualiser"
                    Command="{Binding ActualiserCommand}"
                    Style="{StaticResource SecondaryButton}"
                    HorizontalAlignment="Right" />
        </Grid>

        <!-- Colonnes Kanban -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ── EN ATTENTE ─────────────────────────────────────────── -->
            <Border Grid.Column="0" Margin="0 0 8 0"
                    Background="{StaticResource SurfaceBrush}" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource WarningBrush}"
                            CornerRadius="8 8 0 0" Padding="16 10">
                        <TextBlock Text="&#9203;  En attente" FontWeight="Bold"
                                   Foreground="White" FontSize="15" />
                    </Border>
                    <ScrollViewer Grid.Row="1" Padding="8">
                        <ItemsControl ItemsSource="{Binding EnAttente}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource CardBrush}"
                                            CornerRadius="6" Padding="12" Margin="0 4">
                                        <StackPanel>
                                            <Grid>
                                                <TextBlock Text="{Binding Id, StringFormat='Commande #{0}'}"
                                                           FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
                                                <TextBlock Text="{Binding DateCreation, StringFormat=HH:mm}"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           HorizontalAlignment="Right" />
                                            </Grid>
                                            <ItemsControl ItemsSource="{Binding Lignes}" Margin="0 6 0 0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="12">
                                                            <Run Text="{Binding Quantite}" />
                                                            <Run Text="x" />
                                                            <Run Text="{Binding NomProduit}" />
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <!-- Boutons de statut -->
                                            <StackPanel Orientation="Horizontal" Margin="0 8 0 0">
                                                <Button Content="En attente"
                                                        Background="{StaticResource WarningBrush}" Foreground="White"
                                                        FontSize="10" Padding="5 3" BorderThickness="0"
                                                        Opacity="0.4" IsEnabled="False" Cursor="Arrow"
                                                        Style="{StaticResource PrimaryButton}"
                                                        Margin="0 0 3 0"/>
                                                <Button Content="En prep."
                                                        Command="{Binding DataContext.PrendreEnChargeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource PrimaryButton}"
                                                        FontSize="10" Padding="5 3" Margin="0 0 3 0"/>
                                                <Button Content="Prete"
                                                        Command="{Binding DataContext.MarquerPreteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SuccessButton}"
                                                        FontSize="10" Padding="5 3"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ── EN PREPARATION ────────────────────────────────────── -->
            <Border Grid.Column="1" Margin="4 0"
                    Background="{StaticResource SurfaceBrush}" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource AccentBrush}"
                            CornerRadius="8 8 0 0" Padding="16 10">
                        <TextBlock Text="&#128293;  En preparation" FontWeight="Bold"
                                   Foreground="White" FontSize="15" />
                    </Border>
                    <ScrollViewer Grid.Row="1" Padding="8">
                        <ItemsControl ItemsSource="{Binding EnPreparation}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource CardBrush}"
                                            CornerRadius="6" Padding="12" Margin="0 4">
                                        <StackPanel>
                                            <Grid>
                                                <TextBlock Text="{Binding Id, StringFormat='Commande #{0}'}"
                                                           FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
                                                <TextBlock Text="{Binding DateCreation, StringFormat=HH:mm}"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           HorizontalAlignment="Right" />
                                            </Grid>
                                            <ItemsControl ItemsSource="{Binding Lignes}" Margin="0 6 0 0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="12">
                                                            <Run Text="{Binding Quantite}" />
                                                            <Run Text="x" />
                                                            <Run Text="{Binding NomProduit}" />
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <!-- Boutons de statut -->
                                            <StackPanel Orientation="Horizontal" Margin="0 8 0 0">
                                                <Button Content="En attente"
                                                        Command="{Binding DataContext.RemettrEnAttenteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Background="{StaticResource WarningBrush}" Foreground="White"
                                                        Style="{StaticResource PrimaryButton}"
                                                        FontSize="10" Padding="5 3" Margin="0 0 3 0"/>
                                                <Button Content="En prep."
                                                        Background="{StaticResource AccentBrush}" Foreground="White"
                                                        FontSize="10" Padding="5 3" BorderThickness="0"
                                                        Opacity="0.4" IsEnabled="False" Cursor="Arrow"
                                                        Style="{StaticResource PrimaryButton}"
                                                        Margin="0 0 3 0"/>
                                                <Button Content="Prete"
                                                        Command="{Binding DataContext.MarquerPreteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SuccessButton}"
                                                        FontSize="10" Padding="5 3"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ── PRETE ──────────────────────────────────────────────── -->
            <Border Grid.Column="2" Margin="8 0 0 0"
                    Background="{StaticResource SurfaceBrush}" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource SuccessBrush}"
                            CornerRadius="8 8 0 0" Padding="16 10">
                        <TextBlock Text="&#9989;  Prete" FontWeight="Bold"
                                   Foreground="White" FontSize="15" />
                    </Border>
                    <ScrollViewer Grid.Row="1" Padding="8">
                        <ItemsControl ItemsSource="{Binding Pretes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource CardBrush}"
                                            CornerRadius="6" Padding="12" Margin="0 4">
                                        <StackPanel>
                                            <Grid>
                                                <TextBlock Text="{Binding Id, StringFormat='Commande #{0}'}"
                                                           FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
                                                <TextBlock Text="{Binding DateCreation, StringFormat=HH:mm}"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           HorizontalAlignment="Right" />
                                            </Grid>
                                            <ItemsControl ItemsSource="{Binding Lignes}" Margin="0 6 0 0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="12">
                                                            <Run Text="{Binding Quantite}" />
                                                            <Run Text="x" />
                                                            <Run Text="{Binding NomProduit}" />
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <!-- Boutons de statut -->
                                            <StackPanel Orientation="Horizontal" Margin="0 8 0 0">
                                                <Button Content="En attente"
                                                        Command="{Binding DataContext.RemettrEnAttenteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Background="{StaticResource WarningBrush}" Foreground="White"
                                                        Style="{StaticResource PrimaryButton}"
                                                        FontSize="10" Padding="5 3" Margin="0 0 3 0"/>
                                                <Button Content="En prep."
                                                        Command="{Binding DataContext.PrendreEnChargeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource PrimaryButton}"
                                                        FontSize="10" Padding="5 3" Margin="0 0 3 0"/>
                                                <Button Content="Prete"
                                                        Background="{StaticResource SuccessBrush}" Foreground="White"
                                                        FontSize="10" Padding="5 3" BorderThickness="0"
                                                        Opacity="0.4" IsEnabled="False" Cursor="Arrow"
                                                        Style="{StaticResource SuccessButton}"
                                                        Margin="0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
