<UserControl x:Class="Borne_de_Commande.Views.GestionCategoriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource PrimaryBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <!-- Titre -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   Text="Gestion des categories" FontSize="22" FontWeight="Bold"
                   Foreground="{StaticResource TextBrush}" Margin="0 0 0 20" />

        <!-- ── DataGrid ────────────────────────────────────────────────── -->
        <Border Grid.Row="1" Grid.Column="0" Margin="0 0 16 0"
                Background="{StaticResource SurfaceBrush}" CornerRadius="8">
            <DataGrid ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding Selected, Mode=TwoWay}"
                      Margin="8">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"  Binding="{Binding Id}"  Width="60" />
                    <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ── Formulaire ─────────────────────────────────────────────── -->
        <Border Grid.Row="1" Grid.Column="1"
                Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="20">
            <StackPanel>
                <TextBlock Text="Formulaire" FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}" Margin="0 0 0 16" />

                <TextBlock Text="Nom de la categorie" Foreground="{StaticResource MutedBrush}"
                           FontSize="12" Margin="0 0 0 4" />
                <TextBox Text="{Binding NomEdition, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0 0 0 16" />

                <Button Content="➕  Ajouter"
                        Command="{Binding AjouterCommand}"
                        Style="{StaticResource SuccessButton}"
                        HorizontalAlignment="Stretch" Margin="0 0 0 8" />

                <Button Content="✏️  Modifier la selection"
                        Command="{Binding ModifierCommand}"
                        Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Stretch" Margin="0 0 0 8" />

                <Button Content="🗑️  Supprimer"
                        Command="{Binding SupprimerCommand}"
                        Style="{StaticResource DangerButton}"
                        HorizontalAlignment="Stretch" Margin="0 0 0 8" />

                <Button Content="🔄  Nouveau"
                        Command="{Binding NouveauCommand}"
                        Style="{StaticResource SecondaryButton}"
                        HorizontalAlignment="Stretch" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
