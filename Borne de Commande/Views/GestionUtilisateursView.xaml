<UserControl x:Class="Borne_de_Commande.Views.GestionUtilisateursView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource PrimaryBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="340" />
        </Grid.ColumnDefinitions>

        <!-- Titre -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   Text="Gestion des utilisateurs" FontSize="22" FontWeight="Bold"
                   Foreground="{StaticResource TextBrush}" Margin="0 0 0 16" />

        <!-- Barre de filtre -->
        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0 0 0 12">
            <TextBlock Text="🔍  Rechercher :" VerticalAlignment="Center"
                       Foreground="{StaticResource MutedBrush}" Margin="0 0 8 0" />
            <TextBox Text="{Binding Filtre, UpdateSourceTrigger=PropertyChanged}"
                     Width="250" />
        </StackPanel>

        <!-- ── DataGrid ────────────────────────────────────────────────── -->
        <Border Grid.Row="2" Grid.Column="0" Margin="0 0 16 0"
                Background="{StaticResource SurfaceBrush}" CornerRadius="8">
            <DataGrid ItemsSource="{Binding Clients}"
                      SelectedItem="{Binding Selected, Mode=TwoWay}"
                      Margin="8">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="N°"      Binding="{Binding NumeroClient}" Width="100" />
                    <DataGridTextColumn Header="Pseudo"  Binding="{Binding Pseudo}"       Width="120" />
                    <DataGridTextColumn Header="Type"    Binding="{Binding TypeClient}"   Width="80" />
                    <DataGridTextColumn Header="Nom"     Binding="{Binding Inscrit.NomComplet}" Width="150" />
                    <DataGridTextColumn Header="Email"   Binding="{Binding Inscrit.Email}" Width="*" />
                    <DataGridTextColumn Header="Tel."    Binding="{Binding Inscrit.Telephone}" Width="110" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ── Formulaire inscription ──────────────────────────────────── -->
        <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="1"
                Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Inscrire un client" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" Margin="0 0 0 16" />

                    <TextBlock Text="Pseudo" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0 0 0 4" />
                    <TextBox Text="{Binding PseudoF, UpdateSourceTrigger=PropertyChanged}" Margin="0 0 0 10" />

                    <TextBlock Text="Prenom *" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0 0 0 4" />
                    <TextBox Text="{Binding PrenomF, UpdateSourceTrigger=PropertyChanged}" Margin="0 0 0 10" />

                    <TextBlock Text="Nom *" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0 0 0 4" />
                    <TextBox Text="{Binding NomF, UpdateSourceTrigger=PropertyChanged}" Margin="0 0 0 10" />

                    <TextBlock Text="Email *" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0 0 0 4" />
                    <TextBox Text="{Binding EmailF, UpdateSourceTrigger=PropertyChanged}" Margin="0 0 0 10" />

                    <TextBlock Text="Mot de passe *" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0 0 0 4" />
                    <PasswordBox x:Name="PwdBox" PasswordChanged="PwdBox_Changed"
                                 Background="#1E2A4A" Foreground="{StaticResource TextBrush}"
                                 BorderBrush="#334070" Padding="8 5" Margin="0 0 0 10" />

                    <TextBlock Text="Telephone" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0 0 0 4" />
                    <TextBox Text="{Binding TelF, UpdateSourceTrigger=PropertyChanged}" Margin="0 0 0 10" />

                    <TextBlock Text="Adresse" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0 0 0 4" />
                    <TextBox Text="{Binding AdresseF, UpdateSourceTrigger=PropertyChanged}"
                             Height="50" TextWrapping="Wrap" AcceptsReturn="True" Margin="0 0 0 16" />

                    <Button Content="✅  Inscrire le client"
                            Command="{Binding InscrireCommand}"
                            Style="{StaticResource SuccessButton}"
                            HorizontalAlignment="Stretch" Margin="0 0 0 8" />
                    <Button Content="🗑️  Supprimer la selection"
                            Command="{Binding SupprimerCommand}"
                            Style="{StaticResource DangerButton}"
                            HorizontalAlignment="Stretch" Margin="0 0 0 8" />
                    <Button Content="🔄  Reinitialiser"
                            Command="{Binding NouveauCommand}"
                            Style="{StaticResource SecondaryButton}"
                            HorizontalAlignment="Stretch" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
