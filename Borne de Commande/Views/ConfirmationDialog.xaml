<Window x:Class="Borne_de_Commande.Views.ConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="" Height="220" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="#1A1A2E" CornerRadius="10"
            BorderBrush="#334070" BorderThickness="1">
        <Grid Margin="28 24 28 24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Titre -->
            <TextBlock x:Name="TitleText" Grid.Row="0"
                       FontSize="16" FontWeight="Bold"
                       Foreground="White" Margin="0 0 0 12"/>

            <!-- Message -->
            <TextBlock x:Name="MessageText" Grid.Row="1"
                       FontSize="13" Foreground="#8892B0"
                       TextWrapping="Wrap" VerticalAlignment="Center"/>

            <!-- Boutons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0 20 0 0">
                <Button Content="Non" Click="BtnNon_Click"
                        Style="{StaticResource SecondaryButton}"
                        Padding="24 10" FontSize="13" Margin="0 0 10 0"/>
                <Button Content="Oui" Click="BtnOui_Click"
                        Style="{StaticResource DangerButton}"
                        Padding="24 10" FontSize="13"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
